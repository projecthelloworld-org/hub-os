# Local demonstration settings for the official Headwind MDM Compose project.
# Use a real DNS name, HTTPS, and new secrets before enrolling field devices.
SQL_BASE=hmdm
SQL_USER=hmdm
SQL_PASS=headwind-local-only
ADMIN_EMAIL=operator@hubos.local
BASE_DOMAIN=localhost
LOCAL_IP=127.0.0.1
PROTOCOL=http
SHARED_SECRET=headwind-local-shared-secret
HMDM_VARIANT=os
DOWNLOAD_CREDENTIALS=
HMDM_URL=https://h-mdm.com/files/hmdm-5.39.2-os.war
CLIENT_VERSION=6.34
FORCE_RECONFIGURE=false
HMDM_HTTP_PORT=8081
HMDM_CLIENT_PORT=31000
