# HubOS runtime
HUBOS_ENV=development
HUBOS_HTTP_PORT=8080
HUBOS_BIND_ADDRESS=127.0.0.1
HUBOS_DEMO_MODE=true
HUBOS_INGEST_KEY=replace-for-any-shared-environment
HUBOS_ADMIN_KEY=replace-for-any-shared-environment
HUBOS_OPERATOR_CONSOLE_ENABLED=true

# PostgreSQL
POSTGRES_DB=hubos
POSTGRES_USER=hubos
POSTGRES_PASSWORD=replace-for-any-shared-environment
HUBOS_DATABASE_URL=postgresql://hubos:replace-for-any-shared-environment@db:5432/hubos?sslmode=disable

# Metabase and local email capture
METABASE_PORT=3001
METABASE_DB_PASSWORD=replace-for-any-shared-environment
METABASE_SITE_URL=http://localhost:3001
METABASE_ENCRYPTION_SECRET_KEY=aHViT3MtbG9jYWwtb25seS1lbmNyeXB0aW9uLWtleQ==
METABASE_ADMIN_FIRST_NAME=HubOS
METABASE_ADMIN_LAST_NAME=Administrator
METABASE_ADMIN_EMAIL=admin@hubos.local
METABASE_ADMIN_PASSWORD=replace-for-any-shared-environment-1
# Optional dedicated PostgreSQL reporting account. Defaults to POSTGRES_USER/PASSWORD locally.
# METABASE_HUBOS_DB_USER=hubos_metabase
# METABASE_HUBOS_DB_PASSWORD=replace-for-any-shared-environment
METABASE_HUBOS_SCHEMAS=analytics,public
MAILPIT_WEB_PORT=8025

# Optional ecosystem ports
HMDM_HTTP_PORT=8081
HMDM_CLIENT_PORT=31000
ODK_HTTPS_PORT=8443
