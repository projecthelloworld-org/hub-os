{
  "name": "hubos-core",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "engines": {
    "bun": ">=1.3.14"
  },
  "scripts": {
    "start": "bun run src/server.js",
    "dev": "bun --watch run src/server.js",
    "worker": "bun run src/worker.js",
    "seed": "bun run src/seed.js",
    "metabase:bootstrap": "bun run src/metabase/bootstrap.js",
    "test": "bun test",
    "check": "bun run tools/check.js",
    "db:new": "bunx dbmate --migrations-dir ../../db/migrations new",
    "db:up": "bunx dbmate --migrations-dir ../../db/migrations --schema-file ../../db/schema.sql up",
    "db:status": "bunx dbmate --migrations-dir ../../db/migrations status"
  },
  "devDependencies": {
    "dbmate": "2.30.0"
  }
}
